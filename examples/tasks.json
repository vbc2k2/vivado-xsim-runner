{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xsim: run current file",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\run_xsim.ps1",
        "-FilePath",
        "${file}",
        "-WorkspaceRoot",
        "${workspaceFolder}"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "xsim: open current file in GUI",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\run_xsim.ps1",
        "-FilePath",
        "${file}",
        "-WorkspaceRoot",
        "${workspaceFolder}",
        "-Gui"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
